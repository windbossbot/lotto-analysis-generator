{
  "name": "lotto-analysis-generator",
  "version": "0.1.0",
  "private": true,
  "description": "A lotto number analysis and recommendation generator with local draw history.",
  "main": "server.js",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "start": "node server.js",
    "start:safe": "node scripts/run-local.js",
    "stop:port": "node scripts/kill-port.js 3210",
    "cleanup:temp": "node scripts/cleanup-temp.js",
    "dev": "node --watch server.js"
  },
  "dependencies": {
    "express": "^4.21.2"
  }
}
